<!DOCTYPE html>
<html>
<head>
    <title>Lab 11 - Home</title>
</head>
<body>
    <h1>Home</h1>

    <% if (locals.user) { %>
        <p>Welcome back, <strong><%= user.email %></strong>!</p>
        <p><a href="/profile">View your Profile</a></p>
        
        <form action="/logout" method="POST">
            <button type="submit">Logout</button>
        </form>
    <% } else { %>
        <p>You are not logged in.</p>
        <p><a href="/login">Login / Register</a></p>
    <% } %>

    <hr />
    <p><a href="/profile">Try to access Protected Profile</a></p>
</body>
</html>